{
  "rules": {
    "rateLimits":       { ".read": false, ".write": false },
    "dedupKeys":        { ".read": false, ".write": false },
    "pendingChanges":   { ".read": false, ".write": false },
    "migrationReports": { ".read": false, ".write": false },
    "securityEvents":   { ".read": false, ".write": false },

    "monthlyBoards":    { ".read": "auth != null", ".write": false },
    "emrSyncLog":       { ".read": "auth != null", ".write": false },
    "roomSyncLog":      { ".read": "auth != null", ".write": false },

    "logs": {
      ".read": "auth != null",
      "$logId": {
        ".write": "auth != null && !data.exists() && newData.exists()"
      }
    },

    "incomingCalls": {
      ".read": "auth != null",
      ".indexOn": ["ts"],
      "$callId": {
        ".write": false
      }
    },

    "userSettings": {
      "$ek": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.token.email.replace('.', ',').replace('@', '_at_') == $ek"
      }
    },

    "$node": {
      ".read":  "auth != null && !$node.beginsWith('_backup_')",
      ".write": "auth != null && !$node.beginsWith('_backup_')"
    }
  }
}
